# OpenClaw Portable - Git Ignore

# ============================================
# 敏感配置文件（包含 API Keys）
# ============================================
config/openclaw.json
data/.last_usb

# ============================================
# 日志文件
# ============================================
*.log
logs/

# ============================================
# 环境变量文件
# ============================================
*.env
.env.*

# ============================================
# 临时文件
# ============================================
.temp/
.tmp/
*.tmp
*.swp
*.swo
*~

# ============================================
# 系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 备份文件
# ============================================
*.bak
*.backup
*.old

# ============================================
# Node.js（如果有）
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.iml
.task-card.md
.review.md
