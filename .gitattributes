# Auto detect text files and perform LF normalization
* text=auto

# BAT files must use CRLF line endings on Windows
*.bat text eol=crlf

# Shell scripts use LF
*.sh text eol=lf

# Python files use LF
*.py text eol=lf

# YAML files use LF
*.yml text eol=lf
*.yaml text eol=lf

# JSON files use LF
*.json text eol=lf

# Markdown files use LF
*.md text eol=lf
