# EditorConfig - https://editorconfig.org

root = true

# Default settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# BAT files must use CRLF and ASCII/ANSI encoding (Windows standard)
[*.bat]
charset = latin1
end_of_line = crlf

# Shell scripts
[*.sh]
end_of_line = lf

# Python
[*.py]
indent_style = space
indent_size = 4

# JavaScript/TypeScript
[*.{js,ts,mjs,cjs}]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
